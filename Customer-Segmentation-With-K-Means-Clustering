m scratch using Keras 3](https://keras.io/examples/vision/image_classification_from_scratch/)\n","- [Image Classification with KerasHub](https://keras.io/keras_hub/guides/classification_with_keras_hub/)\n"]},{"cell_type":"code","source":["\n","%matplotlib inline\n","import matplotlib.pyplot as plt\n","plt.style.use('seaborn-v0_8-whitegrid')\n","import numpy as np"],"metadata":{"id":"pLoPS4TLIJDW","executionInfo":{"status":"ok","timestamp":1775473098703,"user_tz":-330,"elapsed":22,"user":{"displayName":"","userId":""}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":[" from sklearn.datasets import make_blobs\n","X, y_true = make_blobs(n_samples=300, centers=4,\n","cluster_std=0.60, random_state=0)\n","plt.scatter(X[:, 0], X[:, 1], s=50);"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":425},"id":"vvt89dSVcTmI","executionInfo":{"status":"ok","timestamp":1775473117514,"user_tz":-330,"elapsed":4251,"user":{"displayName":"","userId":""}},"outputId":"7e826c57-78c5-4a45-dd87-176a2406c201"},"execution_count":2,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[" from sklearn.cluster import KMeans\n","kmeans = KMeans(n_clusters=4)\n","kmeans.fit(X)\n","y_kmeans = kmeans.predict(X)"],"metadata":{"id":"WlLi44oVcbce","executionInfo":{"status":"ok","timestamp":1775473263849,"user_tz":-330,"elapsed":1776,"user":{"displayName":"","userId":""}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":[" plt.scatter(X[:, 0], X[:, 1], c=y_kmeans, s=50, cmap='viridis')\n","centers = kmeans.cluster_centers_\n","plt.scatter(centers[:, 0], centers[:, 1], c='black', s=200);"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":425},"id":"dtCV82dHc_yA","executionInfo":{"status":"ok","timestamp":1775473283572,"user_tz":-330,"elapsed":307,"user":{"displayName":"","userId":""}},"outputId":"e35936fd-daec-4a05-df17-111ed68c34e1"},"execution_count":4,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[" from sklearn.metrics import pairwise_distances_argmin\n","def find_clusters(X, n_clusters, rseed=2):\n","    # 1. Randomly choose clusters\n","    rng = np.random.RandomState(rseed)\n","    i = rng.permutation(X.shape[0])[:n_clusters]\n","    centers = X[i]\n","    while True:\n","        # 2a. Assign labels based on closest center\n","        labels = pairwise_distances_argmin(X, centers)\n","        # 2b. Find new centers from means of points\n","        new_centers = np.array([X[labels == i].mean(0)\n","                                for i in range(n_clusters)])\n","        # 2c. Check for convergence\n","        if np.all(centers == new_centers):\n","            break\n","        centers = new_centers\n","    return centers, labels\n","centers, labels = find_clusters(X, 4)\n","plt.scatter(X[:, 0], X[:, 1], c=labels,\n","            s=50, cmap='viridis');"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":425},"id":"1nf6tg2QdE3i","executionInfo":{"status":"ok","timestamp":1775473372849,"user_tz":-330,"elapsed":194,"user":{"displayName":"","userId":""}},"outputId":"77bd591a-8c67-418c-8e54-697be3451686"},"execution_count":6,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[" centers, labels = find_clusters(X, 4, rseed=0)\n","plt.scatter(X[:, 0], X[:, 1], c=labels,\n","s=50, cmap='viridis');"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":425},"id":"5rqUXeMadP7T","executionInfo":{"status":"ok","timestamp":1775473400984,"user_tz":-330,"elapsed":369,"user":{"displayName":"","userId":""}},"outputId":"6c098eee-2e3a-4c2c-ff98-610908936216"},"execution_count":7,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure